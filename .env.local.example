# Shopify
# Obtenir depuis : Shopify Admin > Apps > Develop apps > Create an app
# Permissions requises : read_products, write_products, read_content, write_content
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Claude (Anthropic)
# Obtenir depuis : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
# Obtenir depuis : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public (visible côté client)
NEXT_PUBLIC_SHOPIFY_DOMAIN=your-store.myshopify.com
